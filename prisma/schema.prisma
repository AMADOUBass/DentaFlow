generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id              String              @id @default(cuid())
  slug            String              @unique
  name            String
  customDomain    String?             @unique
  phone           String
  email           String
  address         String
  city            String
  postalCode      String
  province        String              @default("QC")
  timezone        String              @default("America/Toronto")
  primaryColor    String              @default("#0F766E")
  logoUrl         String?
  locale          String              @default("fr-CA")
  bilingual       Boolean             @default(true)
  planTier        PlanTier            @default(ESSENTIEL)
  stripeCustomer  String?             @unique
  stripeSubId     String?             @unique
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  isActive        Boolean             @default(true)
  isValidated     Boolean             @default(false)
  neq             String?
  appointments    Appointment[]
  auditLogs       AuditLog[]
  businessHours   BusinessHours[]
  clinicalNotes   ClinicalNote[]
  emergencies     EmergencyRequest[]
  insurances      InsuranceProvider[]
  invoices        Invoice[]
  notifications   Notification[]
  patients        Patient[]
  media           PatientMedia[]
  payments        Payment[]
  practitioners   Practitioner[]
  prescriptions   Prescription[]
  services        Service[]
  toothConditions ToothCondition[]
  users           User[]
  medicalQuestionnaires MedicalQuestionnaire[]
}

model User {
  id        String         @id @default(cuid())
  authId    String         @unique
  email     String         @unique
  name      String
  role      UserRole
  tenantId  String?
  createdAt DateTime       @default(now())
  media     PatientMedia[]
  tenant    Tenant?        @relation(fields: [tenantId], references: [id])
  auditLogs AuditLog[]
}

model Practitioner {
  id              String                 @id @default(cuid())
  tenantId        String
  firstName       String
  lastName        String
  title           String
  specialty       String?
  bio             String?
  photoUrl        String?
  active          Boolean                @default(true)
  color           String                 @default("#0EA5E9")
  createdAt       DateTime               @default(now())
  appointments    Appointment[]
  clinicalNotes   ClinicalNote[]
  invoices        Invoice[]
  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  schedules       PractitionerSchedule[]
  prescriptions   Prescription[]
  services        ServicePractitioner[]
  toothConditions ToothCondition[]
}

model Service {
  id            String                @id @default(cuid())
  tenantId      String
  name          String
  nameEn        String?
  description   String?
  durationMin   Int
  priceCents    Int?
  category      ServiceCategory
  active        Boolean               @default(true)
  order         Int                   @default(0)
  imageUrl      String?
  requiresDeposit Boolean             @default(false)
  depositAmountCents Int?
  requiresQuestionnaire Boolean         @default(false)
  createdAt     DateTime              @default(now())
  appointments  Appointment[]
  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  practitioners ServicePractitioner[]
}

model ServicePractitioner {
  serviceId      String
  practitionerId String
  practitioner   Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([serviceId, practitionerId])
}

model BusinessHours {
  id        String  @id @default(cuid())
  tenantId  String
  weekday   Int
  openTime  String
  closeTime String
  closed    Boolean @default(false)
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, weekday])
}

model PractitionerSchedule {
  id             String       @id @default(cuid())
  practitionerId String
  weekday        Int
  startTime      String
  endTime        String
  lunchStart     String?
  lunchEnd       String?
  practitioner   Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)
}

model TimeOff {
  id             String   @id @default(cuid())
  practitionerId String
  startDate      DateTime
  endDate        DateTime
  reason         String?
}

model Patient {
  id                  String             @id @default(cuid())
  tenantId            String
  authId              String?            @unique
  firstName           String
  lastName            String
  email               String
  phone               String
  dateOfBirth         DateTime?
  ramqNumber          String?
  address             String?
  insuranceProviderId String?
  insurancePolicy     String?
  medicalNotes        String?
  consentLoi25        Boolean            @default(false)
  consentDate         DateTime?
  smsOptIn            Boolean            @default(true)
  createdAt           DateTime           @default(now())
  appointments        Appointment[]
  clinicalNotes       ClinicalNote[]
  invoices            Invoice[]
  insuranceProvider   InsuranceProvider? @relation(fields: [insuranceProviderId], references: [id])
  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  media               PatientMedia[]
  prescriptions       Prescription[]
  toothConditions     ToothCondition[]
  auditLogs           AuditLog[]
  questionnaire       MedicalQuestionnaire?

  @@unique([tenantId, email])
  @@index([tenantId, lastName, firstName])
  @@index([tenantId, phone])
}

model Invoice {
  id              String        @id @default(cuid())
  tenantId        String
  patientId       String
  practitionerId  String?
  status          InvoiceStatus @default(DRAFT)
  totalAmount     Float
  subtotal        Float
  taxTPS          Float         @default(0)
  taxTVQ          Float         @default(0)
  insuranceShare  Float         @default(0)
  patientShare    Float         @default(0)
  stripeSessionId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  patient         Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  practitioner    Practitioner? @relation(fields: [practitionerId], references: [id])
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items           InvoiceItem[]
  payments        Payment[]

  @@index([patientId, createdAt])
  @@index([practitionerId])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  actCode     String
  description String
  amount      Float
  quantity    Int     @default(1)
  isTaxable   Boolean @default(false)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id        String        @id @default(cuid())
  tenantId  String
  invoiceId String
  amount    Float
  method    PaymentMethod
  reference String?
  createdAt DateTime      @default(now())
  invoice   Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model PatientMedia {
  id             String   @id @default(cuid())
  tenantId       String
  patientId      String
  practitionerId String?
  url            String
  storagePath    String
  name           String
  fileType       String
  category       String   @default("PHOTO")
  notes          String?
  createdAt      DateTime @default(now())
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  practitioner   User?    @relation(fields: [practitionerId], references: [id])
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([patientId])
}

model InsuranceProvider {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  coveragePercent Int       @default(80)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patients        Patient[]
}

model Appointment {
  id             String            @id @default(cuid())
  tenantId       String
  patientId      String
  practitionerId String
  serviceId      String
  startsAt       DateTime
  endsAt         DateTime
  status         AppointmentStatus @default(PENDING)
  notes          String?
  reminderSent   Boolean           @default(false)
  reminder2hSent Boolean           @default(false)
  confirmedAt    DateTime?
  cancelledAt    DateTime?
  cancelReason   String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  patient        Patient           @relation(fields: [patientId], references: [id])
  practitioner   Practitioner      @relation(fields: [practitionerId], references: [id])
  service        Service           @relation(fields: [serviceId], references: [id])
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, startsAt])
  @@index([practitionerId, startsAt])
}

model EmergencyRequest {
  id          String            @id @default(cuid())
  tenantId    String
  firstName   String
  lastName    String
  phone       String
  email       String?
  painLevel   Int
  category    EmergencyCategory
  description String
  handled     Boolean           @default(false)
  createdAt   DateTime          @default(now())
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String        @id @default(cuid())
  tenantId    String
  userId      String?
  patientId   String?
  action      AuditAction
  category    AuditCategory
  description String
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime      @default(now())
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User?         @relation(fields: [userId], references: [id])
  patient     Patient?      @relation(fields: [patientId], references: [id])

  @@index([tenantId, createdAt])
  @@index([patientId])
}

model ClinicalNote {
  id             String       @id @default(cuid())
  tenantId       String
  patientId      String
  practitionerId String
  content        String
  type           String       @default("GENERIC")
  isLocked       Boolean      @default(false)
  lockedAt       DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  practitioner   Practitioner @relation(fields: [practitionerId], references: [id])
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
}

model ToothCondition {
  id             String       @id @default(cuid())
  tenantId       String
  patientId      String
  toothNumber    Int
  surface        String?
  condition      String
  notes          String?
  practitionerId String
  createdAt      DateTime     @default(now())
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  practitioner   Practitioner @relation(fields: [practitionerId], references: [id])
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([patientId, toothNumber])
}

model Prescription {
  id             String       @id @default(cuid())
  tenantId       String
  patientId      String
  practitionerId String
  medication     String
  dosage         String
  frequency      String
  duration       String
  notes          String?
  createdAt      DateTime     @default(now())
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  practitioner   Practitioner @relation(fields: [practitionerId], references: [id])
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
}

model WebhookLog {
  id        String   @id @default(cuid())
  type      String
  provider  String   @default("STRIPE")
  payload   Json?
  status    String
  error     String?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  title     String
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isRead])
}

enum PlanTier {
  ESSENTIEL
  COMPLET
  PREMIUM
}

enum UserRole {
  SUPERADMIN
  CLINIC_OWNER
  CLINIC_STAFF
  PRACTITIONER
  PATIENT
}

enum ServiceCategory {
  PREVENTION
  RESTORATION
  SURGERY
  ESTHETIC
  ENDODONTICS
  ORTHODONTICS
  EMERGENCY
  OTHER
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
  VOID
}

enum PaymentMethod {
  CREDIT_CARD
  CASH
  DEBIT
  INTERAC
  INSURANCE
  STRIPE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum EmergencyCategory {
  PAIN
  TRAUMA
  INFECTION
  BROKEN_TOOTH
  LOST_FILLING
  OTHER
}

enum AuditAction {
  LOGIN
  LOGOUT
  VIEW
  CREATE
  UPDATE
  DELETE
  EXPORT
  DOWNLOAD
}

enum AuditCategory {
  AUTH
  PATIENT_DATA
  MEDICAL_RECORDS
  SECURITY
  BILLING
  SYSTEM
}

model MedicalQuestionnaire {
  id               String   @id @default(cuid())
  tenantId         String
  patientId        String   @unique
  conditions       Json?
  medications      String?
  allergies        String?
  heartIssues      Boolean  @default(false)
  diabetes         Boolean  @default(false)
  highBloodPressure Boolean @default(false)
  bloodThinners    Boolean  @default(false)
  isPregnant       Boolean  @default(false)
  isSmoker         Boolean  @default(false)
  surgeries        String?
  lastVisitDate    DateTime?
  signature        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  patient          Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}
